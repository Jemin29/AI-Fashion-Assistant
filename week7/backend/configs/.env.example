# =============================================================================
# AI Fashion Assistant FastAPI Backend Environment Variables Example
# Copy this file to '.env' in week7/backend/configs/ and customize settings.
# =============================================================================

# Application Meta
APP_NAME="AI Fashion Assistant API"
APP_VERSION="1.0.0"

# Web Server Settings (Uvicorn / Gunicorn)
SERVER__HOST="127.0.0.1"
SERVER__PORT=8000
SERVER__DEBUG=true
SERVER__RELOAD=true
SERVER__WORKERS=1

# Security and JWT Configurations
# WARNING: Change JWT_SECRET_KEY in production to a cryptographically secure 32-character key!
SECURITY__JWT_SECRET_KEY="production-secret-signing-key-placeholder-32-chars"
SECURITY__JWT_ALGORITHM="HS256"
SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=60
SECURITY__BCRYPT_ROUNDS=12

# Database Settings
DATABASE__SQLITE_URL="sqlite:///./fashion_assistant.db"
DATABASE__CHROMA_DB_DIR="./outputs/chroma_db"
DATABASE__HISTORY_FILE_PATH="./outputs/history.jsonl"

# Machine Learning Engine Settings
MODEL__SDXL_MODEL_ID="stabilityai/stable-diffusion-xl-base-1.0"
MODEL__LORA_CACHE_DIR="./outputs/loras"
MODEL__GLOBAL_MOCK=true
