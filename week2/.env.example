# =============================================================================
# Week 2 — AI Fashion Design Assistant: Text-to-Image Generation
# .env.example — Copy to .env and fill in your values
# =============================================================================

# ── Hugging Face ─────────────────────────────────────────────────────────────
# Your HF token for downloading gated models (e.g. SDXL).
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
HF_HOME=.cache/huggingface                  # Local HF cache directory

# ── Model Selection ───────────────────────────────────────────────────────────
# Stable Diffusion XL base model ID on HuggingFace Hub
SDXL_BASE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# SDXL refiner model ID (optional, improves detail at high resolutions)
SDXL_REFINER_MODEL=stabilityai/stable-diffusion-xl-refiner-1.0
# SDXL VAE override (optional — leave blank to use model default)
SDXL_VAE_MODEL=madebyollin/sdxl-vae-fp16-fix

# ── Compute / Inference ───────────────────────────────────────────────────────
# DEVICE: auto | cuda | cpu | mps
DEVICE=auto
# Torch dtype: float16 | bfloat16 | float32
TORCH_DTYPE=float16
# Enable xformers memory-efficient attention (true/false)
ENABLE_XFORMERS=true
# Enable CPU offload for low-VRAM systems (true/false)
ENABLE_CPU_OFFLOAD=false
# Enable sequential CPU offload (slower but minimum VRAM, true/false)
ENABLE_SEQUENTIAL_OFFLOAD=false

# ── Generation Defaults ───────────────────────────────────────────────────────
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
DEFAULT_STEPS=30
DEFAULT_GUIDANCE_SCALE=7.5
DEFAULT_REFINER_STRENGTH=0.3      # Fraction of steps given to refiner
DEFAULT_NUM_IMAGES=1
DEFAULT_SEED=-1                   # -1 for random seed each run

# ── Output & Storage ──────────────────────────────────────────────────────────
OUTPUT_DIR=week2/outputs/images
METADATA_DIR=week2/outputs/metadata
# Maximum images stored before auto-cleanup (0 = unlimited)
MAX_OUTPUT_IMAGES=500

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=week2/logs
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
LOG_COLORIZE=true

# ── Evaluation ────────────────────────────────────────────────────────────────
# CLIP model for semantic similarity evaluation
CLIP_MODEL_NAME=ViT-L-14
CLIP_PRETRAINED=openai
# Minimum aesthetic score to auto-keep an image (0.0–10.0)
AESTHETIC_THRESHOLD=5.0
# Enable CLIP evaluation after every generation (true/false)
EVAL_ON_GENERATE=false

# ── Prompt Engineering ────────────────────────────────────────────────────────
# Maximum prompt length in tokens (SDXL supports up to 77 per encoder)
MAX_PROMPT_TOKENS=77
# Comma-separated global style booster tags appended to every prompt
GLOBAL_STYLE_BOOSTERS=photorealistic,8k,ultra detailed,fashion photography
# Comma-separated global negative prompt tags
GLOBAL_NEGATIVE_TAGS=blurry,deformed,ugly,watermark,text,signature

# ── API Keys (for future Week 3 integrations) ────────────────────────────────
# Leave these empty — Week 3 only
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# ── Development ───────────────────────────────────────────────────────────────
DEBUG_MODE=false
PROFILE_INFERENCE=false
SAVE_INTERMEDIATE_LATENTS=false
