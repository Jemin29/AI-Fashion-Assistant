# Week 6 Environment Variables
# Copy to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
FASHION_STUDIO_HOST=0.0.0.0
FASHION_STUDIO_PORT=7860
FASHION_STUDIO_SHARE=false

# ── Mock Mode ────────────────────────────────────────────────────────────────
# Set to true to run without GPU (uses deterministic mock responses)
FASHION_STUDIO_MOCK_MODE=true

# ── Logging ───────────────────────────────────────────────────────────────────
FASHION_STUDIO_LOG_LEVEL=INFO
FASHION_STUDIO_LOG_DIR=week6/logs

# ── HuggingFace (required for real model downloads) ───────────────────────────
HUGGINGFACE_TOKEN=hf_your_token_here

# ── Model Paths (optional overrides) ─────────────────────────────────────────
SDXL_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMADB_IN_MEMORY=true
CHROMADB_PERSIST_DIR=week5/chromadb_store

# ── Device ────────────────────────────────────────────────────────────────────
TORCH_DEVICE=auto    # auto | cuda | cpu | mps
