  "validation_rules": {
    "required_fields": ["image_id", "category", "gender", "dataset_source"],
    "conditional_rules": [
      {
        "rule_id": "CR001",
        "description": "Dresses are only valid for gender=women",
        "condition": "category == 'dresses'",
        "required": "gender in ['women']",
        "severity": "error"
      },
      {
        "rule_id": "CR002",
        "description": "Ethnic wear must specify an occasion",
        "condition": "category == 'ethnic_wear'",
        "required": "occasion is not null",
        "severity": "warning"
      },
      {
        "rule_id": "CR003",
        "description": "Formal style requires formal or business_casual occasion",
        "condition": "style == 'formal'",
        "required": "occasion in ['formal', 'business_casual', 'wedding_festive']",
        "severity": "warning"
      },
      {
        "rule_id": "CR004",
        "description": "Athleisure style requires appropriate categories",
        "condition": "style == 'athleisure'",
        "required": "category in ['t_shirts', 'hoodies', 'shorts', 'pants', 'footwear']",
        "severity": "warning"
      },
      {
        "rule_id": "CR005",
        "description": "Techwear fabrics should be technical",
        "condition": "style == 'techwear'",
        "recommended_fabrics": ["Gore-Tex", "Nylon", "Ripstop Nylon", "Cordura", "Performance Mesh"],
        "severity": "info"
      }
    ],
    "attribute_constraints": {
      "fit": {
        "skinny": {
          "only_applies_to": ["jeans", "pants", "t_shirts"]
        },
        "cropped": {
          "only_applies_to": ["t_shirts", "hoodies", "jackets", "pants"]
        }
      },
      "season": {
        "summer": {
          "incompatible_fabrics": ["Wool", "Fleece", "Gore-Tex", "Cordura"]
        },
        "winter": {
          "incompatible_fabrics": ["Linen", "Performance Mesh"]
        }
      }
    }
  }
