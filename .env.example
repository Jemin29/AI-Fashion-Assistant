# =============================================================================
# AI-Powered Fashion Design Assistant
# .env.example — Environment Variable Template (Master Reference)
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file to create your environment config:
#      - Local Dev: cp .env.example .env
#      - Production: cp .env.example .env.production
#   2. Fill in your actual credentials/configurations.
#   3. NEVER commit .env or .env.production containing secrets.
# =============================================================================

# ─── Project Identity ─────────────────────────────────────────────────────────
PROJECT_NAME="AI Fashion Design Assistant"
PROJECT_VERSION="1.0.0"
ENVIRONMENT="development"              # development | staging | production
GLOBAL_MOCK=true                      # Set false to run full ML/GPU inference

# ─── Web Server Settings (FastAPI & Uvicorn) ──────────────────────────────────
# Note: Pydantic nested settings are configured using double underscores '__'
SERVER__HOST="127.0.0.1"               # Bind address (use 0.0.0.0 in Docker)
SERVER__PORT=8000                      # Listening port
SERVER__DEBUG=true                     # Enable FastAPI debug logs (disable in prod)
SERVER__RELOAD=true                    # Auto-reload on code change (disable in prod)
SERVER__WORKERS=1                      # Number of server processes (use 4+ in prod)
SERVER__ALLOWED_ORIGINS="[\"*\"]"       # CORS allowed origins JSON list

# ─── Security Settings (JWT Authentication & Hashing) ───────────────────────
SECURITY__JWT_SECRET_KEY="your-jwt-secret-key-at-least-32-characters-long"
SECURITY__JWT_ALGORITHM="HS256"
SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=60
SECURITY__BCRYPT_ROUNDS=12             # Work factor for password hashing

# ─── Database & Vector Store Settings ───────────────────────────────────────
DATABASE__SQLITE_URL="sqlite:///./fashion_assistant.db"
DATABASE__CHROMA_DB_DIR="./outputs/chroma_db"
DATABASE__HISTORY_FILE_PATH="./outputs/history.jsonl"

# ─── Redis Caching & Celery Queue Settings ──────────────────────────────────
REDIS__HOST="127.0.0.1"                # Use 'redis' inside Docker Compose
REDIS__PORT=6379
REDIS__DB=0
REDIS__PASSWORD=""                     # Production Redis access password
REDIS__ENABLED=true
REDIS__MOCK_FALLBACK=true              # In-memory mock if Redis is down

# ─── Celery Queue Configurations ─────────────────────────────────────────────
CELERY_BROKER_URL="redis://127.0.0.1:6379/1"
CELERY_RESULT_BACKEND="redis://127.0.0.1:6379/2"
CELERY_CONCURRENCY=2
CELERY_PREFETCH_MULTIPLIER=1

# ─── Standalone ChromaDB Vector Server Coordinates ──────────────────────────
CHROMA_SERVER_HOST="127.0.0.1"         # Use 'chromadb' inside Docker Compose
CHROMA_SERVER_PORT=8000

# ─── Machine Learning Model Settings ─────────────────────────────────────────
MODEL__SDXL_MODEL_ID="stabilityai/stable-diffusion-xl-base-1.0"
MODEL__LORA_CACHE_DIR="./outputs/loras"
MODEL__GLOBAL_MOCK=true                # Set false to activate GPU pipeline

# ─── Dataset API Credentials ─────────────────────────────────────────────────
# Kaggle (required for DeepFashion download)
# Get from: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# HuggingFace Hub (optional — for gated model/dataset access)
HUGGINGFACE_TOKEN=hf_your_huggingface_token_here

# Google Drive (used by gdown for FashionGen downloads)
GDRIVE_COOKIE_PATH=./configs/gdrive_cookies.txt

# ─── Storage Paths ───────────────────────────────────────────────────────────
RAW_DATA_DIR=./datasets
PROCESSED_DATA_DIR=./datasets/processed
METADATA_DIR=./datasets/metadata
OUTPUT_DIR=./outputs

# ─── Dataset Configs ──────────────────────────────────────────────────────────
FASHIONGEN_HDF5_PATH=./datasets/fashiongen/fashiongen_256_256.h5
FASHIONGEN_SPLIT=train                 # train | val | test
DEEPFASHION_ROOT=./datasets/deepfashion
DEEPFASHION_SPLIT=train                # train | val | test
MAX_IMAGES_PER_RUN=5000

# ─── Preprocessing & Data Validation ────────────────────────────────────────
GE_DATA_CONTEXT_ROOT=./configs/great_expectations
MIN_IMAGE_WIDTH=64
MIN_IMAGE_HEIGHT=64
MAX_IMAGE_SIZE_MB=50
TARGET_IMAGE_SIZE=256
IMAGE_FORMAT=JPEG                      # JPEG | PNG | WEBP
JPEG_QUALITY=95
NORMALIZE_MEAN="0.485,0.456,0.406"
NORMALIZE_STD="0.229,0.224,0.225"
NUM_WORKERS=4

# ─── Telemetry & Logging Configuration ───────────────────────────────────────
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=./logs
LOG_ROTATION="10 MB"
LOG_RETENTION="30 days"
CLIP_MODEL_NAME=ViT-B/32
TEXT_EMBED_MODEL=all-MiniLM-L6-v2
DEVICE=cpu                             # cpu | cuda | mps
EMBED_BATCH_SIZE=32
CHROMA_PERSIST_DIR=./outputs/chroma_db
CHROMA_COLLECTION_NAME=fashion_embeddings
