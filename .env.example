# =============================================================================
# AI-Powered Fashion Design Assistant
# .env.example — Environment Variable Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual credentials in .env
#   3. NEVER commit .env to version control (it is in .gitignore)
#   4. Rotate credentials immediately if accidentally exposed
# =============================================================================

# ─── Project Identity ─────────────────────────────────────────────────────────
PROJECT_NAME="AI Fashion Design Assistant"
PROJECT_VERSION="1.0.0"
WEEK_NUMBER=1
ENVIRONMENT="development"         # development | staging | production
DEBUG=true                        # Set false in production

# ─── Dataset API Credentials ─────────────────────────────────────────────────

# Kaggle (required for DeepFashion download)
# Get from: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# HuggingFace Hub (optional — for gated model/dataset access)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_huggingface_token_here

# Google Drive (used by gdown for FashionGen downloads)
# No key needed for public files; set cookie for private files
GDRIVE_COOKIE_PATH=./configs/gdrive_cookies.txt

# ─── Storage Paths ───────────────────────────────────────────────────────────

# Root directory where raw datasets will be downloaded
RAW_DATA_DIR=./datasets

# Directory for processed/cleaned dataset outputs
PROCESSED_DATA_DIR=./datasets/processed

# Directory for all metadata JSON/CSV/Parquet files
METADATA_DIR=./datasets/metadata

# Directory for model outputs and embeddings
OUTPUT_DIR=./outputs

# ─── Dataset Configuration ───────────────────────────────────────────────────

# FashionGen — HDF5 based dataset
FASHIONGEN_HDF5_PATH=./datasets/fashiongen/fashiongen_256_256.h5
FASHIONGEN_SPLIT=train                # train | val | test

# DeepFashion — Image + annotation based dataset
DEEPFASHION_ROOT=./datasets/deepfashion
DEEPFASHION_SPLIT=train               # train | val | test

# Maximum images to process per run (set -1 for full dataset)
MAX_IMAGES_PER_RUN=5000

# ─── Logging Configuration ───────────────────────────────────────────────────
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=./logs
LOG_ROTATION="10 MB"                  # Loguru rotation size per file
LOG_RETENTION="30 days"              # How long to keep log files

# ─── Model & Embedding Configuration ─────────────────────────────────────────

# CLIP model for image-text embeddings
CLIP_MODEL_NAME=ViT-B/32             # ViT-B/32 | ViT-L/14 | ViT-H-14

# Sentence transformer for text embedding
TEXT_EMBED_MODEL=all-MiniLM-L6-v2

# Device for inference (auto-detected if not set)
DEVICE=cpu                           # cpu | cuda | mps

# Batch size for embedding generation
EMBED_BATCH_SIZE=32

# ─── Vector Store Configuration ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=./outputs/chroma_db
CHROMA_COLLECTION_NAME=fashion_embeddings

# ─── Data Validation ─────────────────────────────────────────────────────────
# Great Expectations data context root
GE_DATA_CONTEXT_ROOT=./configs/great_expectations

# Minimum image resolution to accept (pixels)
MIN_IMAGE_WIDTH=64
MIN_IMAGE_HEIGHT=64

# Maximum file size in MB for a single image
MAX_IMAGE_SIZE_MB=50

# ─── Preprocessing Parameters ─────────────────────────────────────────────────
TARGET_IMAGE_SIZE=256                # Output image size (square)
IMAGE_FORMAT=JPEG                    # JPEG | PNG | WEBP
JPEG_QUALITY=95                      # JPEG compression quality (1-100)
NORMALIZE_MEAN="0.485,0.456,0.406"  # ImageNet mean for normalization
NORMALIZE_STD="0.229,0.224,0.225"   # ImageNet std for normalization

# ─── Parallel Processing ──────────────────────────────────────────────────────
NUM_WORKERS=4                        # CPU worker threads for data loading
